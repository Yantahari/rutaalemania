---
import BaseLayout from '../layouts/BaseLayout.astro';
import CalculadoraChancenkarte from '../components/CalculadoraChancenkarte.astro';
import SimuladorVida from '../components/SimuladorVida.astro';

const homeSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'RutaAlemania',
  url: 'https://rutaalemania.com',
  description: 'Guía práctica para hispanohablantes que quieren trabajar en Alemania.',
  author: {
    '@type': 'Person',
    name: 'Carlos Domínguez Cid',
  },
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://rutaalemania.com/blog/?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};

const blogPostFiles = import.meta.glob('./blog/*.md', { eager: true });
const blogPosts = Object.values(blogPostFiles) as any[];
const latestPosts = blogPosts
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime())
  .slice(0, 3);
---

<BaseLayout
  title="RutaAlemania — Tu guia para trabajar en Alemania"
  description="Guia practica, calculadora Chancenkarte gratuita y recursos para hispanohablantes que quieren emigrar y trabajar en Alemania."
  keywords="trabajar en alemania, emigrar a alemania, chancenkarte, visa alemania, trabajo alemania"
  schema={homeSchema}
  hideNewsletter={true}
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-coal text-white">
    <div class="absolute inset-0">
      <img src="/img/hero-germany.jpg" alt="" class="w-full h-full object-cover opacity-30" />
    </div>
    <div class="container-wide relative py-20 md:py-32 text-center">
      <div class="badge mb-6 !bg-white/10 !border-white/20 !text-amber">Guia gratuita para hispanohablantes</div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold leading-tight mb-6 max-w-4xl mx-auto text-white">
        Tu camino para trabajar en <em class="text-amber italic">Alemania</em> empieza aqui
      </h1>
      <p class="text-white/70 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        Calculadora Chancenkarte gratuita, guias practicas paso a paso y recursos verificados.
        De hispanohablante a hispanohablante, desde Alemania.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#calculadora" class="btn-primary text-lg px-8 py-4">
          Calcula tus puntos gratis
        </a>
        <a href="/blog/" class="inline-block border border-white/20 text-white font-semibold px-8 py-4 rounded-xl hover:border-amber/50 hover:text-amber transition-all duration-200 text-lg">
          Leer guias
        </a>
      </div>
    </div>
  </section>

  <!-- FEATURES STRIP -->
  <section class="border-b border-border bg-surface">
    <div class="container-wide py-10 md:py-14">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 text-center">
        <div>
          <div class="w-12 h-12 mx-auto mb-3 rounded-xl bg-amber-glow flex items-center justify-center">
            <svg class="w-6 h-6 text-amber" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
          </div>
          <p class="text-text-primary font-semibold text-sm">Calculadora Chancenkarte</p>
          <p class="text-text-muted text-xs mt-1">Test gratuito en 2 min</p>
        </div>
        <div>
          <div class="w-12 h-12 mx-auto mb-3 rounded-xl bg-amber-glow flex items-center justify-center">
            <svg class="w-6 h-6 text-amber" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <p class="text-text-primary font-semibold text-sm">Simulador de costes</p>
          <p class="text-text-muted text-xs mt-1">Salario, gastos y ahorro</p>
        </div>
        <div>
          <div class="w-12 h-12 mx-auto mb-3 rounded-xl bg-amber-glow flex items-center justify-center">
            <svg class="w-6 h-6 text-amber" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          </div>
          <p class="text-text-primary font-semibold text-sm">10+ guias completas</p>
          <p class="text-text-muted text-xs mt-1">Visa, trabajo, burocracia</p>
        </div>
        <div>
          <div class="w-12 h-12 mx-auto mb-3 rounded-xl bg-amber-glow flex items-center justify-center">
            <svg class="w-6 h-6 text-amber" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <p class="text-text-primary font-semibold text-sm">Escrito desde Alemania</p>
          <p class="text-text-muted text-xs mt-1">Experiencia real y actual</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT ME (brief) -->
  <section class="container-wide py-16 md:py-24" id="sobre-mi">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <div class="badge mb-4">Sobre mi</div>
        <h2 class="text-3xl md:text-4xl font-heading mb-6">
          Soy <span class="text-amber">Carlos</span>, y ya hice este camino
        </h2>

        <p class="text-text-secondary leading-relaxed mb-5">
          Biologo de vocacion, pase a la ensenanza para compartir mi pasion por la naturaleza.
        </p>

        <p class="text-text-secondary leading-relaxed mb-5">
          <strong class="text-text-primary">La paternidad me llevo a Alemania</strong>, donde tuve que reinventarme:
          aprender un idioma nuevo, adaptarme a otra cultura y navegar la burocracia alemana.
        </p>

        <p class="text-text-secondary leading-relaxed mb-6">
          Ahora vivo en Freiburg y ayudo a otros hispanohablantes a simplificar el proceso.
          <strong class="text-text-primary">No soy abogado</strong> — soy alguien que paso por todo esto y quiere ahorrarte tiempo y frustraciones.
        </p>

        <a href="/sobre-mi/" class="text-amber font-semibold hover:underline">
          Conoce mi historia completa &rarr;
        </a>
      </div>
      <div>
        <img
          src="/img/city-freiburg.jpg"
          alt="Ciudad alemana"
          class="rounded-2xl shadow-lg w-full h-auto object-cover mb-6"
        />
        <div class="space-y-4">
          <div class="card p-5 flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-amber-glow flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-amber" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <h3 class="font-heading text-base mb-1">Desde Freiburg, Alemania</h3>
              <p class="text-text-muted text-sm">Informacion practica y actualizada, porque vivo aqui.</p>
            </div>
          </div>
          <div class="card p-5 flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-amber-glow flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-amber" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            </div>
            <div>
              <h3 class="font-heading text-base mb-1">De hispanohablante a hispanohablante</h3>
              <p class="text-text-muted text-sm">Sin jerga legal. Todo explicado como te lo contaria un amigo.</p>
            </div>
          </div>
          <div class="card p-5 flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-amber-glow flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-amber" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <h3 class="font-heading text-base mb-1">Informacion verificada</h3>
              <p class="text-text-muted text-sm">Fuentes oficiales, datos actualizados a 2026.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CALCULADORA CHANCENKARTE -->
  <section class="bg-surface-muted py-16 md:py-24" id="calculadora">
    <div class="container-narrow">
      <CalculadoraChancenkarte />
    </div>
  </section>

  <!-- SIMULADOR -->
  <section class="container-wide py-16 md:py-24" id="simulador">
    <div class="text-center mb-12">
      <div class="badge mb-4">Herramienta interactiva</div>
      <h2 class="text-3xl md:text-4xl font-heading mb-4">
        Simulador de vida en <span class="text-amber">Alemania</span>
      </h2>
      <p class="text-text-secondary max-w-xl mx-auto">
        Descubre cuanto ganarias, cuanto gastarias y cuanto te quedaria libre cada mes segun tu profesion y ciudad.
      </p>
    </div>
    <SimuladorVida />
  </section>

  <!-- BLOG PREVIEW -->
  <section class="bg-surface-muted py-20 md:py-28">
    <div class="container-wide">
      <div class="text-center mb-14">
        <div class="badge mb-4">Blog</div>
        <h2 class="text-3xl md:text-4xl font-heading mb-5">Guias practicas</h2>
        <p class="text-text-secondary max-w-xl mx-auto leading-relaxed">
          Articulos detallados sobre visas, burocracia, costes y todo lo que necesitas saber
          para trabajar y vivir en Alemania.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {latestPosts.map(post => (
          <a href={post.url} class="card group">
            <p class="text-xs text-amber mb-2">
              {new Date(post.frontmatter.date).toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' })}
            </p>
            <h3 class="font-heading text-lg mb-2 group-hover:text-amber transition-colors">
              {post.frontmatter.title}
            </h3>
            <p class="text-text-muted text-sm leading-relaxed line-clamp-3">
              {post.frontmatter.description}
            </p>
          </a>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/blog/" class="btn-secondary">Ver todos los articulos &rarr;</a>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="container-narrow py-16 md:py-20">
    <div class="text-center mb-8">
      <div class="badge mb-4">Newsletter</div>
      <h2 class="text-3xl md:text-4xl font-heading mb-4">
        Recibe consejos en tu <span class="text-amber">email</span>
      </h2>
      <p class="text-text-secondary max-w-xl mx-auto">
        Tips practicos, novedades sobre visados y recursos exclusivos para emigrar a Alemania. Sin spam.
      </p>
    </div>
    <div class="max-w-xl mx-auto">
      <div class="ml-embedded" data-form="h47itn"></div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="container-wide py-20 md:py-28">
    <div class="bg-coal rounded-3xl p-10 md:p-16 text-center text-white">
      <h2 class="text-3xl md:text-4xl font-heading mb-6 text-white">
        Listo para dar el primer paso?
      </h2>
      <p class="text-white/60 max-w-xl mx-auto mb-5 leading-relaxed">
        Haz el test gratuito de Chancenkarte y descubre en 2 minutos si cumples los requisitos.
      </p>
      <p class="text-white/60 max-w-xl mx-auto mb-10 leading-relaxed">
        Explora nuestros recursos y empieza a planificar tu nueva vida en Alemania.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#calculadora" class="btn-primary">Calculadora Chancenkarte</a>
        <a href="/recursos/" class="inline-block border border-white/20 text-white font-semibold px-6 py-3 rounded-xl hover:border-amber/50 hover:text-amber transition-all duration-200">Ver recursos</a>
      </div>
    </div>
  </section>

  <!-- AD SPACE -->
  <div class="container-narrow py-8">
    <div class="p-6 bg-surface border border-dashed border-border rounded-xl text-center text-xs text-text-muted">
      [ Espacio reservado para Google AdSense ]
    </div>
  </div>
</BaseLayout>
