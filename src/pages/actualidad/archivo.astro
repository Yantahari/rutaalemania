---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const all = await getCollection('actualidad');
const sorted = all.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const archive = sorted.slice(10);

const groupedByYear: Record<string, typeof archive> = {};
for (const entry of archive) {
  const year = new Date(entry.data.date).getFullYear().toString();
  (groupedByYear[year] ??= []).push(entry);
}
const years = Object.keys(groupedByYear).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout
  title="Archivo de noticias — Actualidad Alemania"
  description="Archivo historico de noticias sobre Alemania: cambios legales, umbrales y novedades para emigrantes hispanohablantes."
  keywords="archivo noticias alemania, historial actualidad alemania"
>
  <section class="container-narrow py-12 md:py-20">
    <nav class="text-sm text-text-muted mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-amber">Inicio</a>
      <span class="mx-2">&rsaquo;</span>
      <a href="/actualidad/" class="hover:text-amber">Actualidad</a>
      <span class="mx-2">&rsaquo;</span>
      <span class="text-text-secondary">Archivo</span>
    </nav>

    <header class="mb-10">
      <div class="badge mb-4">Archivo</div>
      <h1 class="text-3xl md:text-4xl font-heading font-bold leading-tight mb-4">
        Noticias anteriores
      </h1>
      <p class="text-text-secondary">
        Todas las noticias que ya no aparecen en el listado principal, ordenadas por fecha.
      </p>
    </header>

    {archive.length === 0 ? (
      <p class="text-text-muted py-8">
        Aun no hay noticias en el archivo. Las noticias pasan aqui cuando el listado principal supera las 10 entradas.
      </p>
    ) : (
      <div class="space-y-10">
        {years.map(year => (
          <div>
            <h2 class="font-heading text-xl text-amber mb-4">{year}</h2>
            <ul class="space-y-3">
              {groupedByYear[year].map(entry => {
                const d = new Date(entry.data.date);
                const formatted = d.toLocaleDateString('es-ES', {
                  day: '2-digit', month: 'short',
                });
                return (
                  <li class="flex gap-4 items-baseline border-b border-border-light pb-3">
                    <span class="text-text-muted text-sm tabular-nums shrink-0 w-20">
                      {formatted}
                    </span>
                    <a
                      href={`/actualidad/${entry.id}/`}
                      class="text-text-primary hover:text-amber transition-colors"
                    >
                      {entry.data.title}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        ))}
      </div>
    )}

    <div class="mt-12">
      <a href="/actualidad/" class="text-amber text-sm font-semibold hover:underline">
        &larr; Volver al listado principal
      </a>
    </div>
  </section>
</BaseLayout>
