---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Links — RutaAlemania"
  description="Todos los recursos, herramientas y guías de RutaAlemania en un solo lugar."
  keywords="rutaalemania links, link in bio rutaalemania"
  noindex={true}
  hideNewsletter={true}
>
  <section class="min-h-screen flex items-center justify-center py-10 px-4">
    <div class="w-full max-w-md">

      <!-- Logo + Tagline -->
      <div class="text-center mb-8">
        <img
          src="/logo-rutaalemania.png"
          alt="RutaAlemania"
          width="96"
          height="96"
          class="mx-auto rounded-2xl mb-4"
        />
        <h1 class="text-2xl font-heading font-bold">
          <span class="text-amber">Ruta</span>Alemania
        </h1>
        <p class="text-text-muted text-sm mt-1.5">Tu guia para emigrar a Alemania</p>
      </div>

      <!-- CTA principal -->
      <a href="https://rutaalemania.com" class="links-cta">
        rutaalemania.com
      </a>

      <!-- Redes sociales -->
      <div class="links-divider">
        <div class="flex-1 h-px bg-border"></div>
        <span class="text-text-muted text-xs uppercase tracking-widest">Redes sociales</span>
        <div class="flex-1 h-px bg-border"></div>
      </div>

      <div class="space-y-2.5">
        <a href="https://www.instagram.com/ruta_alemania/" target="_blank" rel="noopener noreferrer" class="link-btn link-btn--social">
          <img src="/logos/instagram.png" alt="Instagram" width="24" height="24" class="link-logo" />
          <span class="flex-1">Instagram</span>
          <span class="link-handle">@ruta_alemania</span>
        </a>
        <a href="https://www.tiktok.com/@rutaalemania" target="_blank" rel="noopener noreferrer" class="link-btn link-btn--social">
          <img src="/logos/tiktok.png" alt="TikTok" width="24" height="24" class="link-logo" />
          <span class="flex-1">TikTok</span>
          <span class="link-handle">@rutaalemania</span>
        </a>
        <a href="https://www.youtube.com/@Ruta_Alemania" target="_blank" rel="noopener noreferrer" class="link-btn link-btn--social">
          <img src="/logos/youtube.png" alt="YouTube" width="24" height="24" class="link-logo" />
          <span class="flex-1">YouTube</span>
          <span class="link-handle">@Ruta_Alemania</span>
        </a>
        <a href="https://www.facebook.com/profile.php?id=61588503670569" target="_blank" rel="noopener noreferrer" class="link-btn link-btn--social">
          <img src="/logos/facebook.png" alt="Facebook" width="24" height="24" class="link-logo" />
          <span class="flex-1">Facebook</span>
          <span class="link-handle">RutaAlemania</span>
        </a>
        <a href="https://x.com/RutaAlemania" target="_blank" rel="noopener noreferrer" class="link-btn link-btn--social">
          <img src="/logos/x.svg" alt="X" width="20" height="20" class="link-logo" />
          <span class="flex-1">X / Twitter</span>
          <span class="link-handle">@RutaAlemania</span>
        </a>
        <a href="https://whatsapp.com/channel/0029VbBz8ru9mrGU3KQWwk03" target="_blank" rel="noopener noreferrer" class="link-btn link-btn--social">
          <img src="/logos/whatsapp.svg" alt="WhatsApp" width="24" height="24" class="link-logo" />
          <span class="flex-1">WhatsApp</span>
          <span class="link-handle">Canal</span>
        </a>
        <a href="https://t.me/rutaalemania" target="_blank" rel="noopener noreferrer" class="link-btn link-btn--social">
          <img src="/logos/telegram.svg" alt="Telegram" width="24" height="24" class="link-logo" />
          <span class="flex-1">Telegram</span>
          <span class="link-handle">@rutaalemania</span>
        </a>
      </div>

      <!-- Afiliados -->
      <div class="links-divider">
        <div class="flex-1 h-px bg-border"></div>
        <span class="text-text-muted text-xs uppercase tracking-widest">Recomendados</span>
        <div class="flex-1 h-px bg-border"></div>
      </div>

      <div class="space-y-2.5">
        <a href="https://a.check24.net/misc/click.php?pid=1169811&aid=18&deep=c24bank&cat=14" target="_blank" rel="noopener noreferrer sponsored" class="link-btn link-btn--c24">
          <img src="/logos/c24.png" alt="C24 Bank" width="28" height="28" class="link-logo link-logo--affiliate" />
          <span class="flex-1">
            <span class="block font-semibold">C24 Bank</span>
            <span class="block text-xs opacity-60">Cuenta bancaria alemana gratis</span>
          </span>
          <span class="link-badge link-badge--c24">Afiliado</span>
        </a>
        <a href="https://a.check24.net/misc/click.php?pid=1169811&aid=18&deep=stromanbieter-wechseln&cat=1" target="_blank" rel="noopener noreferrer sponsored" class="link-btn link-btn--check24">
          <img src="/logos/check24.png" alt="CHECK24" width="28" height="28" class="link-logo link-logo--affiliate" />
          <span class="flex-1">
            <span class="block font-semibold">CHECK24 Servicios</span>
            <span class="block text-xs opacity-60">Compare internet, electricidad y gas</span>
          </span>
          <span class="link-badge link-badge--check24">Afiliado</span>
        </a>
        <a href="https://tidd.ly/4vxmVpv" target="_blank" rel="noopener noreferrer sponsored" class="link-btn link-btn--lyca">
          <img src="/logos/lycamobile.png" alt="Lyca Mobile" width="28" height="28" class="link-logo link-logo--affiliate" style="object-fit:contain" />
          <span class="flex-1">
            <span class="block font-semibold">Lyca Mobile</span>
            <span class="block text-xs opacity-60">SIM alemana gratis, llamadas baratas a LATAM</span>
          </span>
          <span class="link-badge link-badge--lyca">Afiliado</span>
        </a>
        <a href="https://a.partner-versicherung.de/click.php?partner_id=200466&ad_id=15&deep=haftpflichtversicherung" target="_blank" rel="noopener noreferrer sponsored" class="link-btn link-btn--tarifcheck">
          <img src="/logos/tarifcheck24.svg" alt="Tarifcheck24" width="28" height="28" class="link-logo link-logo--affiliate" />
          <span class="flex-1">
            <span class="block font-semibold">Tarifcheck24 — Seguros</span>
            <span class="block text-xs opacity-60">Responsabilidad civil, hogar, mascotas</span>
          </span>
          <span class="link-badge link-badge--tarifcheck">Afiliado</span>
        </a>
        <a href="https://www.expatrio.com/?p=rutaalemania" target="_blank" rel="noopener noreferrer sponsored" class="link-btn link-btn--expatrio">
          <img src="/logos/expatrio-icon.png" alt="Expatrio" width="28" height="28" class="link-logo link-logo--affiliate" />
          <span class="flex-1">
            <span class="block font-semibold">Expatrio</span>
            <span class="block text-xs opacity-60">Abre tu Sperrkonto</span>
          </span>
          <span class="link-badge link-badge--expatrio">Afiliado</span>
        </a>
        <a href="https://wise.prf.hn/click/camref:1110lAp2W" target="_blank" rel="noopener noreferrer sponsored" class="link-btn link-btn--wise">
          <img src="/logos/wise.svg" alt="Wise" width="28" height="28" class="link-logo link-logo--affiliate link-logo--wide" />
          <span class="flex-1">
            <span class="block font-semibold">Wise</span>
            <span class="block text-xs opacity-60">Transfiere dinero sin comisiones ocultas</span>
          </span>
          <span class="link-badge link-badge--wise">Afiliado</span>
        </a>
        <a href="https://www.l16sh94jd.com/ZCHQXN/55M6S/?uid=48" target="_blank" rel="noopener noreferrer sponsored" class="link-btn link-btn--lingoda">
          <img src="/logos/lingoda.svg" alt="Lingoda" width="28" height="28" class="link-logo link-logo--affiliate" />
          <span class="flex-1">
            <span class="block font-semibold">Lingoda</span>
            <span class="block text-xs opacity-60">Aprende alemán con profesores nativos</span>
          </span>
          <span class="link-badge link-badge--lingoda">Afiliado</span>
        </a>
      </div>

      <!-- Footer -->
      <div class="text-center mt-10 text-text-muted text-xs">
        &copy; 2026 RutaAlemania.com
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  /* CTA principal dorado */
  .links-cta {
    display: block;
    width: 100%;
    text-align: center;
    padding: 1rem 1.5rem;
    background: #e2a730;
    color: #1a1a2e;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 1.05rem;
    border-radius: 0.875rem;
    text-decoration: none;
    transition: all 0.2s ease;
    box-shadow: 0 4px 20px rgba(226, 167, 48, 0.25);
  }
  .links-cta:hover {
    background: #f0b840;
    transform: translateY(-1px);
    box-shadow: 0 6px 28px rgba(226, 167, 48, 0.35);
  }

  /* Divider */
  .links-divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.25rem 0 0.75rem;
  }

  /* Base button — light theme */
  .link-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    padding: 0.8rem 1rem;
    background: #ffffff;
    border: 1px solid #e5e0d5;
    border-radius: 0.75rem;
    color: #1f2937;
    font-size: 0.95rem;
    font-family: 'DM Sans', sans-serif;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .link-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  /* Social buttons */
  .link-btn--social:hover {
    background: rgba(226, 167, 48, 0.06);
    border-color: rgba(226, 167, 48, 0.35);
  }
  .link-logo {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    object-fit: contain;
  }
  .link-logo--affiliate {
    width: 28px;
    height: 28px;
    border-radius: 0.375rem;
  }
  .link-logo--wide {
    width: 48px;
    height: 28px;
  }
  .link-handle {
    font-size: 0.8rem;
    color: #9ca3af;
    flex-shrink: 0;
  }

  /* Badge base */
  .link-badge {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.5rem;
    border-radius: 0.375rem;
    flex-shrink: 0;
  }

  /* C24 Bank — blue brand */
  .link-btn--c24:hover {
    background: rgba(0, 82, 180, 0.06);
    border-color: rgba(0, 82, 180, 0.35);
  }
  .link-badge--c24 {
    background: rgba(0, 82, 180, 0.12);
    color: #0052b4;
  }

  /* CHECK24 — blue/yellow brand */
  .link-btn--check24:hover {
    background: rgba(0, 68, 153, 0.06);
    border-color: rgba(0, 68, 153, 0.35);
  }
  .link-badge--check24 {
    background: rgba(0, 68, 153, 0.12);
    color: #004499;
  }

  /* Tarifcheck24 — blue brand */
  .link-btn--tarifcheck:hover {
    background: rgba(0, 90, 156, 0.06);
    border-color: rgba(0, 90, 156, 0.35);
  }
  .link-badge--tarifcheck {
    background: rgba(0, 90, 156, 0.12);
    color: #005a9c;
  }

  /* Expatrio — teal/green brand */
  .link-btn--expatrio:hover {
    background: rgba(0, 186, 173, 0.06);
    border-color: rgba(0, 186, 173, 0.35);
  }
  .link-badge--expatrio {
    background: rgba(0, 186, 173, 0.12);
    color: #009e94;
  }

  /* Wise — green brand */
  .link-btn--wise:hover {
    background: rgba(100, 200, 60, 0.06);
    border-color: rgba(100, 200, 60, 0.35);
  }
  .link-badge--wise {
    background: rgba(100, 200, 60, 0.12);
    color: #4a9e2f;
  }

  /* Lingoda — purple brand */
  .link-btn--lingoda:hover {
    background: rgba(124, 58, 237, 0.06);
    border-color: rgba(124, 58, 237, 0.35);
  }
  .link-badge--lingoda {
    background: rgba(124, 58, 237, 0.12);
    color: #7c3aed;
  }

  /* Lyca Mobile — red brand */
  .link-btn--lyca:hover {
    background: rgba(227, 6, 19, 0.06);
    border-color: rgba(227, 6, 19, 0.35);
  }
  .link-badge--lyca {
    background: rgba(227, 6, 19, 0.12);
    color: #c00510;
  }
</style>
